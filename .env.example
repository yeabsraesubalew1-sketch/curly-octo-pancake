# --- MongoDB ---
# Connection string for your MongoDB database. Use a local instance
# (e.g. mongodb://127.0.0.1:27017/edusched) or a hosted cluster such as
# MongoDB Atlas (mongodb+srv://<user>:<password>@<cluster>/edusched).
MONGODB_URI="mongodb://127.0.0.1:27017/edusched"

# --- Auth ---
# Secret used to sign/verify JWTs. Use a long, random string in production.
JWT_SECRET="MY_JWT_SECRET"
# How long a login session stays valid, e.g. "12h", "7d".
JWT_EXPIRES_IN="12h"

# --- Server ---
# Port the Express API listens on.
PORT=5000
